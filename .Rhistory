# bell-shaped
# d.)
prop.test(
length(sim_data[sim_data > 60]),
length(sim_data),
conf.level = 0.95,
p = proportion
)
# Question 2
# a.)
set.seed(123)
sim_data <- rnorm(1000, mean = 50, sd = 10)
# b.)
proportion = length(sim_data[sim_data > 60])/length(sim_data)
# c.)
hist(
sim_data,
main = "Histogram of Random Normal Data",
xlab = "Values",
ylab = "Frequency",
col = "lightblue",
border = "black",
breaks = 25
)
# bell-shaped
# d.)
prop.test(
x = length(sim_data[sim_data > 60]),
n = length(sim_data),
conf.level = 0.95
)
