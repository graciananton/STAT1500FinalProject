knitr::opts_chunk$set(echo = TRUE)
library(dplyr)
library(tidyr)
library(ggplot2)
data(mpg)
head(mpg, n = 10)
help(mpg)
help(round)
help(dim)
help(ifelse)
mpg_clean <- mpg %>%
select(manufacturer, model, year, cyl, displ, cty, hwy, class, drv) %>%
mutate(avg_mpg = round((cty+hwy)/2, 1)) %>%
mutate(efficiency_rating = case_when(
avg_mpg < 20 ~ "Low",
avg_mpg >= 20 & avg_mpg <= 25 ~ "Medium",
avg_mpg > 25 ~ "High"
)) %>%
mutate(engine_size = ifelse(displ < 2.5, "Small", "Large"))
head(mpg_clean, n = 5)
dim(mpg_clean) # returns row by columns
glimpse(mpg_clean)
subsetA <- mpg_clean %>%
filter(efficiency_rating == "High" & engine_size == "Small")
subsetA
nrow(subsetA)
subsetB <- mpg_clean %>%
filter(class %in% c('compact','subcompact','midsize'))
subsetB
nrow(subsetB)
subsetC <- mpg_clean %>%
filter(year == 2008 & (manufacturer == "honda" | manufacturer == "toyota"))
subsetC
nrow(subsetC)
subsetD <- mpg_clean %>%
filter(cyl >= 6  & (cty < 20 & hwy < 20))
subsetD
nrow(subsetD)
mpg_clean %>%
group_by(manufacturer) %>%
summarize(
mean_mpg = round(mean(avg_mpg, na.rm = TRUE), digits = 2),
mean_displ = round(mean(displ, na.rm = TRUE), digits = 2),
num_models = n()
) %>%
arrange(-mean_mpg) %>%
slice_head(n = 5)
mpg_clean %>%
group_by(class, year) %>%
summarize(
median_hwy = median(hwy, na.rm = TRUE),
median_cty = median(cty, na.rm = TRUE)
) %>%
arrange(class) %>%
arrange(year)
mpg_clean %>%
group_by(drv) %>%
summarize(
mean_hwy = round(mean(hwy, na.rm = TRUE), 2),
sd_hwy = round(sd(hwy, na.rm = TRUE), 2),
min_cty = min(cty, na.rm = TRUE),
max_cty = max(cty, na.rm = TRUE)
)
library(tidyverse)
data(mpg)
mpg %>%
ggplot(mapping = aes(x=displ, y = hwy, color = factor(class), size = factor(cyl), shape = factor())) + geom_point(shape = 16, alpha = 0.6) + theme_minimal()
